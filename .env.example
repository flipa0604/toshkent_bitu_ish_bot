# ===== Telegram =====
# Bot tokenini @BotFather'dan olasiz
TELEGRAM_API_TOKEN=your_bot_token_here

# Anketalar yuboriladigan HR chat/guruh ID si
# Botni guruhga qo'shib, /here buyrug'i bilan olishingiz mumkin
HR_CHAT_ID=-1000000000000

# ===== Bot mode =====
# POLLING yoki WEBHOOK
RUN_MODE=POLLING

# WEBHOOK rejimi uchun (POLLING ishlatilsa, kerak emas)
PUBLIC_BASE_URL=https://your-domain.com
WEBHOOK_PORT=8443
WEBHOOK_PATH=/telegram/webhook

# ===== Language =====
# uz yoki ru
LANG=uz

# ===== Media files =====
# Bot avtomatik yuboradigan namuna fayllar
ASK_VOICE_PATH=ask_voice.ogg
ASK_VIDEO_NOTE_PATH=ask_video.mp4

# ===== Google Sheets =====
# 1 = yoqilgan, 0 = o'chirilgan
GSHEETS_ENABLE=1

# Google Cloud'dan olingan service account JSON fayl
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# Google Sheets jadval ID si (URL'dagi uzun kod)
GSHEET_SPREADSHEET_ID=your_spreadsheet_id_here

# Jadval ichidagi varaq nomi
GSHEET_WORKSHEET_NAME=Applications
